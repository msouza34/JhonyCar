# Docker security defaults (copy to .env and adjust)
POSTGRES_DB=jhonycar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-por-uma-senha-forte

REDIS_PASSWORD=troque-por-uma-senha-forte
JWT_SECRET=troque-por-um-segredo-longo-com-64-caracteres-ou-mais
JWT_EXPIRATION_MS=86400000

FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=5173
FRONTEND_API_BASE_URL=/api

APP_BASE_URL=http://localhost:5173/api
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false
